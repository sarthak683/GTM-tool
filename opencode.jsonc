{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "docs/ai/opencode.md",
    "docs/ai/README.md"
  ],
  "permission": {
    "bash": "ask",
    "edit": "ask"
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true,
      "timeout": 120000
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true,
      "timeout": 120000
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true,
      "timeout": 120000
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true,
      "timeout": 120000
    },
    "postgres-local": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://beacon:beacon_dev@localhost:5432/beacon_crm"
      ],
      "enabled": true,
      "timeout": 120000
    },
    "filesystem-repo": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/sarthak/GTM-tool"
      ],
      "enabled": true,
      "timeout": 120000
    },
    "github-local": {
      "type": "local",
      "command": [
        "sh",
        "-lc",
        "GITHUB_PERSONAL_ACCESS_TOKEN=\"$(gh auth token)\" exec npx -y @modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "timeout": 120000
    }
  }
}
